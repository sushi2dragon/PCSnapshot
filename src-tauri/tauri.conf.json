{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PC Snapshot",
  "version": "0.1.0",
  "identifier": "com.pc-snapshot",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PC Snapshot",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#1c1c1f"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src ipc: http://ipc.localhost; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/Snapshots/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
